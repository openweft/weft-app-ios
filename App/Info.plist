<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>Weft</string>
    <key>CFBundleIdentifier</key>
    <string>io.openweft.weftapp</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- The DC origins are reached over the WireGuard mesh / SSH forward,
         which provide encryption; the webui listener is plain HTTP on a
         private address. Allow cleartext to those private hosts only.
         Tighten NSExceptionDomains once the real endpoints are known. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
