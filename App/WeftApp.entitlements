<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Personal VPN / packet-tunnel for the WireGuard transport. -->
    <key>com.apple.developer.networking.networkextension</key>
    <array>
        <string>packet-tunnel-provider</string>
    </array>
    <!-- Shared container so the app and the tunnel extension exchange the
         WireGuard config. Replace TEAMID at signing time. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.io.openweft.weftapp</string>
    </array>
</dict>
</plist>
